# ======================================================================
# LangLearn configuration template.
# Copy this file to `.env` in the SAME directory, then fill in your values.
# The real `.env` is gitignored — your credentials will not be committed.
# ======================================================================

# ---------- SMTP 邮件配置（用于密码重置验证码）----------
#
# 选一个邮件服务商，填下面 5 行即可。
# 如果全部留空或不存在 .env 文件，验证码会直接显示在网页上（dev 模式）。

# ==== QQ 邮箱（推荐给国内用户）====
# 1. 登录 mail.qq.com
# 2. 设置 → 账户 → 找到 "POP3/IMAP/SMTP/Exchange/CardDAV/CalDAV 服务"
# 3. 开启 "IMAP/SMTP 服务"，根据指引生成 16 位授权码
# 4. 授权码就是下面的 SMTP_PASS（不是 QQ 登录密码）
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=你的qq号@qq.com
SMTP_PASS=你的16位授权码
SMTP_FROM=你的qq号@qq.com
SMTP_FROM_NAME=LangLearn 多语言学习

# ==== 163 邮箱 ====
# SMTP_HOST=smtp.163.com
# SMTP_PORT=465
# SMTP_USER=你的邮箱@163.com
# SMTP_PASS=你的授权码
# SMTP_FROM=你的邮箱@163.com

# ==== Gmail（需要"应用专用密码" App Password）====
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=yourname@gmail.com
# SMTP_PASS=16 位 App Password（不是 Google 账户密码）
# SMTP_FROM=yourname@gmail.com
